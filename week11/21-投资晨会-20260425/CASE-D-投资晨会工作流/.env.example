# ============================================================
# MySQL 连接（与 CASE-A / CASE-B 同一套）
# ============================================================
WUCAI_SQL_HOST=localhost
WUCAI_SQL_PORT=3306
WUCAI_SQL_USERNAME=root
WUCAI_SQL_PASSWORD=
WUCAI_SQL_DB=wucai_trade

# ============================================================
# 推送（晨会消息）
# ============================================================

# 钉钉自定义机器人 webhook（无配置则只在控制台打印）
DINGTALK_WEBHOOK=https://oapi.dingtalk.com/robot/send?access_token=xxxxxxxxx

# 企业微信群机器人 webhook（可选）
WECOM_WEBHOOK=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=xxxxx
